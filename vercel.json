{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npx ng build --configuration production",
  "outputDirectory": "frontend/dist/renmito-frontend/browser",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/:path*",     "destination": "/index.html" }
  ]
}
