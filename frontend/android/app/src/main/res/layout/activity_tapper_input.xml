<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/tapper_sheet_bg"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="16dp"
    android:paddingBottom="20dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="14dp"
        android:background="#3A3F6E" />

    <!-- "Tapped at HH:mm" / "Logging tap…" -->
    <TextView
        android:id="@+id/tv_tapped_at"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tapper_creating"
        android:textColor="#B0B8FF"
        android:textSize="12sp"
        android:letterSpacing="0.06"
        android:layout_marginBottom="14dp" />

    <!--
        Options + custom input — hidden while the POST is in-flight,
        revealed once we have a noteId to update.
    -->
    <LinearLayout
        android:id="@+id/options_wrapper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Chip grid — rows of 2 chips each, populated in code -->
        <LinearLayout
            android:id="@+id/options_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="10dp"
            android:background="#2A2D52" />

        <!-- Custom text row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/et_note"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/tapper_hint"
                android:textColorHint="#5A5F8A"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:maxLength="30"
                android:maxLines="1"
                android:singleLine="true"
                android:inputType="text"
                android:backgroundTint="#3A3F6E"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginEnd="10dp" />

            <Button
                android:id="@+id/btn_save"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tapper_save"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/btn_time_tap_bg"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="9dp"
                android:paddingBottom="9dp"
                android:enabled="false" />

        </LinearLayout>

    </LinearLayout>

    <!-- Done — always visible, closes the sheet -->
    <Button
        android:id="@+id/btn_done"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:layout_marginTop="10dp"
        android:text="@string/tapper_done"
        android:textColor="#5A5F8A"
        android:textSize="13sp"
        android:background="@android:color/transparent"
        android:minHeight="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:paddingStart="0dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp" />

</LinearLayout>
