DB_USERNAME=your_mongo_username
DB_PASSWORD=your_mongo_password
JWT_SECRET=your_random_secret_string_min_32_chars

# Master key: when set, this password bypasses bcrypt and grants access to any account.
# Use a long random string. Leave unset (or blank) to disable the feature entirely.
# Set this in the Vercel dashboard under Environment Variables as MASTER_KEY.
MASTER_KEY=

# Allowed CORS origin for the frontend.
# Local dev: http://localhost:4200
# Vercel:    * (frontend and backend share the same domain)
CORS_ORIGIN=http://localhost:4200

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@renmito.app

# Cron secret — protects the /api/notifications/cron endpoint
# Add to vercel.json path: /api/notifications/cron?secret=<this value>
CRON_SECRET=
