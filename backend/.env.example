DB_USERNAME=your_mongo_username
DB_PASSWORD=your_mongo_password
JWT_SECRET=your_random_secret_string_min_32_chars

# Master key: when set, this password bypasses bcrypt and grants access to any account.
# Use a long random string. Leave unset (or blank) to disable the feature entirely.
# Set this in the Vercel dashboard under Environment Variables as MASTER_KEY.
MASTER_KEY=

# Allowed CORS origin for the frontend.
# Local dev (web):    http://localhost:4200
# Local dev (mobile): http://localhost:4200,https://localhost,capacitor://localhost
# Vercel production:  * (frontend and backend share the same domain)
CORS_ORIGIN=http://localhost:4200,https://localhost,capacitor://localhost

# Intelligence (Python) service — run with: cd intelligence && uvicorn app.main:app --reload
# In production, set IC_SERVICE_URL to the deployed Python service URL.
IC_SERVICE_URL=http://localhost:8000
IC_INTERNAL_SECRET=

# AES-256 key for encrypting JIRA API tokens stored in MongoDB.
# Use a long random string (32+ chars). Falls back to JWT_SECRET if unset.
ENCRYPTION_KEY=
